# ============================================================
# Vet AI Operating System — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────
# Get from: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection (for server-side queries via postgres.js)
# Get from: supabase.com → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ── AI (Replicate) ────────────────────────────────────────────────
# Get from: replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# AI Assistant model (Replicate model identifier)
AI_ASSISTANT_PROVIDER=replicate
AI_ASSISTANT_MODEL=meta/meta-llama-3-70b-instruct

# ── Microsoft 365 / Azure AD (optional — for Outlook calendar sync) ──
# Register app at: portal.azure.com → Azure AD → App registrations
MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_REDIRECT_URI=https://your-app.onrender.com/api/v1/calendar/outlook/callback

# Outlook webhook secret (random string you choose)
OUTLOOK_WEBHOOK_SECRET=your-random-secret-string-here

# ── Email (Resend) ────────────────────────────────────────────────
# Get from: resend.com/api-keys
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.onrender.com

# ── Security ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-64-char-hex-string-here

# Cron job auth token (set same value in Render cron config)
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here
